{% extends 'base.html.twig' %}
{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>salutation</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-white">

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card bg-secondary text-white shadow-lg p-5 text-center" style="width: 450px;">

        <h1 class="mb-3">
             Bonjour <span class="text-warning">{{ prenom }} {{ nom }}</span> !
        </h1>

        <hr class="border-warning">

        <p class="fs-5">
             Nous sommes le <span class="badge bg-warning text-dark fs-6">{{ date }}</span>
        </p>

        <a href="{{ path('accueil') }}" class="btn btn-outline-warning mt-3">
            ← Retour à l'accueil
        </a>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
{% endblock %}