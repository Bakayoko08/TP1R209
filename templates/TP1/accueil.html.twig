{% extends 'base.html.twig' %}

{% block body %}
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Accueil</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-dark text-white">

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card bg-secondary text-white shadow-lg p-4" style="width: 400px;">
        
        <h2 class="card-title text-center mb-4">
            <span class="badge bg-warning text-dark">Identification</span>
        </h2>

        <!-- Formulaire en GET -->
        <form action="{{ path('salutation') }}" method="GET">

            <div class="mb-3">
                <label for="prenom" class="form-label">Prénom</label>
                <input type="text" 
                       class="form-control bg-dark text-white border-warning"
                       id="prenom" name="prenom"
                       placeholder="Entrez votre prénom" required>
            </div>

            <div class="mb-3">
                <label for="nom" class="form-label">Nom</label>
                <input type="text" 
                       class="form-control bg-dark text-white border-warning"
                       id="nom" name="nom"
                       placeholder="Entrez votre nom" required>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-warning text-dark fw-bold">
                    Valider
                </button>
            </div>

        </form>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

{% endblock %}

